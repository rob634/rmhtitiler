        "method": "GET",
        "path": "/vector/collections/{test_data.vector.collection_id}",
        "params": {},
        "expected_status": 200
      },
      {
        "id": "vector-items",
        "method": "GET",
        "path": "/vector/collections/{test_data.vector.collection_id}/items",
