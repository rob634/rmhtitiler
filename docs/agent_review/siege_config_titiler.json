      "xarray_variables": "GET  /xarray/variables?url={url}",
      "xarray_info": "GET  /xarray/info?url={url}&variable={variable}",
      "xarray_bounds": "GET  /xarray/bounds?url={url}&variable={variable}",
      "xarray_tilejson": "GET  /xarray/WebMercatorQuad/tilejson.json?url={url}&variable={variable}&bidx={bidx}&rescale={rescale}",
      "vector_collections": "GET  /vector/collections",
      "vector_collection": "GET  /vector/collections/{collection_id}",
      "vector_items": "GET  /vector/collections/{collection_id}/items",
      "vector_tilejson": "GET  /vector/collections/{collection_id}/tiles/WebMercatorQuad/tilejson.json",
      "vector_tile": "GET  /vector/collections/{collection_id}/tiles/WebMercatorQuad/{z}/{x}/{y}",
      "stac_collections": "GET  /stac/collections",
      "stac_collection": "GET  /stac/collections/{collection_id}",
      "stac_items": "GET  /stac/collections/{collection_id}/items",
      "stac_search": "GET  /stac/search"
    },
    "verification_endpoints": {
      "_comment": "Read-only endpoints for auditing and state verification — never for test actions.",
      "health": "GET  /health",
      "livez": "GET  /livez",
      "readyz": "GET  /readyz",
      "vector_diagnostics": "GET  /vector/diagnostics"
    }
  },
