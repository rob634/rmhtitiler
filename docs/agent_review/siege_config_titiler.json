        "expected_status": 200
      },
      {
        "id": "vector-tilejson",
        "method": "GET",
        "path": "/vector/collections/{test_data.vector.collection_id}/tiles/WebMercatorQuad/tilejson.json",
        "params": {},
        "expected_status": 200
      }
    ],
    "stac": [
      {
        "id": "stac-collections",
        "method": "GET",
        "path": "/stac/collections",
        "params": {},
        "expected_status": 200
      },
      {
        "id": "stac-collection",
        "method": "GET",
        "path": "/stac/collections/{test_data.stac.collection_id}",
        "params": {},
        "expected_status": 200
      },
      {
        "id": "stac-items",
        "method": "GET",
        "path": "/stac/collections/{test_data.stac.collection_id}/items",
        "params": { "limit": "3" },
        "expected_status": 200
      },
      {
        "id": "stac-search",
        "method": "GET",
        "path": "/stac/search",
        "params": { "limit": "3" },
        "expected_status": 200
      }
    ],
    "health": [
      {
        "id": "health",
        "method": "GET",
        "path": "/health",
        "params": {},
        "expected_status": 200
      },
      {
        "id": "livez",
        "method": "GET",
        "path": "/livez",
        "params": {},
        "expected_status": 200
      },
      {
        "id": "readyz",
        "method": "GET",
